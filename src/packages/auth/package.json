    "lru-cache": "^7.18.3",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.16.14",
    "@types/uuid": "^8.3.4"
  },
  "homepage": "https://github.com/sagemathinc/cocalc/tree/master/src/packages/auth",
