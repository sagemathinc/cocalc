{
  "name": "@cocalc/sdk",
  "version": "0.0.1",
  "description": "SDK for building CoCalc applications and extensions",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "rm -rf node_modules dist",
    "build": "pnpm exec tsc --build && pnpm run build-builtin",
    "build-builtin": "node ./scripts/build-builtin-archives.mjs",
    "serve-builtin": "cd dist/builtin && python3 -m http.server 4312",
    "test": "echo 'no tests yet'"
  },
  "files": [
    "dist/**",
    "typings/**",
    "package.json"
  ],
  "license": "SEE LICENSE.md",
  "devDependencies": {
    "@types/react": "^19.1.10",
    "csv-parse": "^5.6.0",
    "esbuild": "^0.25.0",
    "react": "^19.1.1",
    "react-virtuoso": "^4.18.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sagemathinc/cocalc"
  }
}
