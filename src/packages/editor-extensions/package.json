{
  "name": "@cocalc/editor-extensions",
  "version": "0.0.1",
  "description": "Thin SDK for CoCalc editor extensions",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "rm -rf node_modules dist",
    "build": "pnpm exec tsc --build && pnpm run build-builtin",
    "build-builtin": "node ./scripts/build-builtin-archives.mjs",
    "serve-builtin": "cd dist/builtin && python3 -m http.server 4312",
    "test": "echo 'no tests yet'"
  },
  "files": [
    "dist/**",
    "typings/**",
    "package.json"
  ],
  "license": "SEE LICENSE.md",
  "devDependencies": {
    "@types/react": "^19.1.10",
    "react": "^19.1.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sagemathinc/cocalc"
  }
}
